digraph GoEmployeeAPI {
    graph [
        goal="Build a Go REST API with a POST /employees endpoint that creates an Employee (id, name, email, department, created_at) and stores it in a SQLite database",
        label="Go Employee REST API"
    ]
    rankdir=LR
    node [shape=box, timeout="900s"]

    start  [shape=Mdiamond, label="Start"]
    exit   [shape=Msquare,  label="Done"]

    scaffold [
        label="Scaffold Project",
        prompt="Create a new Go project for a REST API. Run 'mkdir -p go-employee-api && cd go-employee-api && go mod init employee-api'. Create the directory structure: main.go, db/db.go, models/employee.go, handlers/employee.go. Install dependencies with 'go get github.com/mattn/go-sqlite3 github.com/gorilla/mux'."
    ]

    model [
        label="Employee Model + DB",
        prompt="In go-employee-api/models/employee.go, define the Employee struct with fields: ID (int64), Name (string), Email (string), Department (string), CreatedAt (time.Time). In go-employee-api/db/db.go, implement InitDB(path string) (*sql.DB, error) that opens the SQLite database and creates the employees table (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT NOT NULL, email TEXT NOT NULL UNIQUE, department TEXT, created_at DATETIME DEFAULT CURRENT_TIMESTAMP) if it does not exist."
    ]

    handler [
        label="POST /employees Handler",
        prompt="In go-employee-api/handlers/employee.go, implement CreateEmployee(db *sql.DB) http.HandlerFunc. It should: decode a JSON request body into an Employee, validate that name and email are non-empty (return 400 on failure), insert the record into the employees table, and respond 201 with the created employee as JSON (including the generated id and created_at). Use proper error handling and set Content-Type: application/json."
    ]

    server [
        label="Wire HTTP Server",
        prompt="In go-employee-api/main.go, wire everything together: call db.InitDB to open (or create) employee.db, register the route POST /employees using gorilla/mux pointing at handlers.CreateEmployee(db), and start listening on :8080. Log the server address on startup."
    ]

    tests [
        label="Write Tests",
        prompt="In go-employee-api/handlers/employee_test.go, write table-driven tests for the CreateEmployee handler using net/http/httptest. Cover: successful creation returns 201 with JSON body containing id and created_at; missing name returns 400; missing email returns 400; duplicate email returns 409."
    ]

    validate [
        label="Run Tests",
        prompt="cd go-employee-api && go build ./... && go test ./... -v. Report the full test output. If any build errors or test failures exist, describe them precisely."
    ]

    gate [shape=diamond, label="All tests pass?"]

    fix [
        label="Fix Failures",
        prompt="The tests or build failed. Review the error output from the previous step and fix all issues — build errors, import paths, SQL errors, or test logic. Do not change the intended behaviour, only fix the defects."
    ]

    review [shape=hexagon, label="Human Review", type="wait.human"]

    start -> scaffold -> model -> handler -> server -> tests -> validate -> gate
    gate -> review     [label="Yes", condition="outcome=success"]
    gate -> fix        [label="No",  condition="outcome!=success"]
    fix -> validate
    review -> exit     [label="[A] Approve & Ship"]
    review -> fix      [label="[F] Fix Issues"]
}
